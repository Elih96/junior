{
  "name": "@sentry/junior-github",
  "version": "0.91.0",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/getsentry/junior.git",
    "directory": "packages/junior-github"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "skills",
    "SETUP.md"
  ],
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json --emitDeclarationOnly",
    "lint": "oxlint --config ../junior/.oxlintrc.json --deny-warnings src tests tsup.config.ts vitest.config.ts",
    "prepare": "pnpm run build",
    "prepack": "pnpm run build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@sentry/junior-plugin-api": "workspace:*",
    "@sinclair/typebox": "^0.34.49",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "msw": "^2.14.6",
    "oxlint": "^1.66.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
